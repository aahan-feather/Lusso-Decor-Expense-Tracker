generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id                  String   @id @default(cuid())
  name                String
  email               String?
  contactPerson1Name   String?
  contactPerson1Phone String?
  contactPerson2Name  String?
  contactPerson2Phone String?
  type                String?  // "Quotation" or "Invoice"
  status              String?  // "Running", "Due", "Closed"
  documentRef         String?  // alphanumeric ID for the quotation/invoice (user-set)
  details             String?  @db.Text // free-form project notes
  invoiceAmount       Float?        // what you're charging for the project
  date                DateTime?     // project date (e.g. quote/invoice date)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  lineItems       LineItem[]
  projectPayments ProjectPayment[]

  @@map("Customer")
}

model LineItem {
  id               String   @id @default(cuid())
  description      String
  amount           Float    // total (rate * qty when rate/qty set)
  rate             Float?   // optional: when set with qty, amount = rate * qty
  qty              Float?   // optional
  date             DateTime @default(now())
  projectId        String   @map("customerId")
  vendorId         String?  // optional: tag vendor against this line item (linked on vendor side when added there)
  paymentMethodId  String?  // optional: Ledger = null
  createdAt        DateTime @default(now())

  project        Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vendor         Vendor?       @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  paymentMethod  PaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  vendorItems    VendorItem[]
}

model PaymentMethod {
  id        String   @id @default(cuid())
  name      String   // e.g. "HDFC Savings", "Google Pay"
  type      String   // bank, upi, cash, other
  createdAt DateTime @default(now())

  lineItems            LineItem[]
  projectPayments      ProjectPayment[]
  vendorPayments       VendorPayment[]
  officeExpenses       OfficeExpense[]
  inventoryExpenses    InventoryExpense[]
  bankOnlyTransactions BankOnlyTransaction[]
}

// Bank charges, interest, etc. — not tied to projects/vendors/office/inventory
model BankOnlyTransaction {
  id                String   @id @default(cuid())
  paymentMethodId   String
  date              DateTime @default(now())
  amount            Float
  direction         String   // in | out
  description       String
  category          String?  // fee | interest | adjustment | other
  createdAt         DateTime @default(now())

  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Cascade)
}

model OfficeExpenseType {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  officeExpenses OfficeExpense[]

  @@map("OfficeExpenseType")
}

model OfficeExpense {
  id                   String   @id @default(cuid())
  description          String
  amount               Float
  date                 DateTime @default(now())
  paymentMethodId      String?
  officeExpenseTypeId  String?
  createdAt            DateTime @default(now())

  paymentMethod      PaymentMethod?       @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  officeExpenseType  OfficeExpenseType?   @relation(fields: [officeExpenseTypeId], references: [id], onDelete: SetNull)

  @@map("OfficeExpense")
}

model InventoryExpenseType {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  inventoryExpenses InventoryExpense[]

  @@map("InventoryExpenseType")
}

model InventoryExpense {
  id                      String   @id @default(cuid())
  description             String
  amount                  Float
  date                    DateTime @default(now())
  paymentMethodId         String?
  inventoryExpenseTypeId  String?
  createdAt               DateTime @default(now())

  paymentMethod         PaymentMethod?         @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  inventoryExpenseType  InventoryExpenseType?  @relation(fields: [inventoryExpenseTypeId], references: [id], onDelete: SetNull)

  @@map("InventoryExpense")
}

model ProjectPayment {
  id              String   @id @default(cuid())
  amount          Float
  date            DateTime @default(now())
  note            String?
  projectId       String   @map("customerId")
  paymentMethodId String?
  createdAt       DateTime @default(now())

  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  paymentMethod  PaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)

  @@map("CustomerPayment")
}

model Vendor {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lineItems     LineItem[]
  vendorItems   VendorItem[]
  vendorPayments VendorPayment[]
}

model VendorItem {
  id         String   @id @default(cuid())
  description String
  amount     Float
  date       DateTime @default(now())
  vendorId   String
  lineItemId String?  // optional: link to project line item
  createdAt  DateTime @default(now())

  vendor     Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  lineItem   LineItem? @relation(fields: [lineItemId], references: [id], onDelete: SetNull)
  allocations VendorPaymentAllocation[]
}

model VendorPayment {
  id              String   @id @default(cuid())
  amount          Float
  date            DateTime @default(now())
  note            String?
  vendorId        String
  paymentMethodId String?
  createdAt       DateTime @default(now())

  vendor     Vendor                    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  paymentMethod PaymentMethod?          @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  allocations VendorPaymentAllocation[]
}

model VendorPaymentAllocation {
  id              String   @id @default(cuid())
  vendorPaymentId String
  vendorItemId    String
  createdAt       DateTime @default(now())

  vendorPayment VendorPayment @relation(fields: [vendorPaymentId], references: [id], onDelete: Cascade)
  vendorItem    VendorItem    @relation(fields: [vendorItemId], references: [id], onDelete: Cascade)

  @@unique([vendorPaymentId, vendorItemId])
}
